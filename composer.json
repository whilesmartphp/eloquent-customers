{
    "name": "whilesmart/eloquent-customers",
    "description": "Polymorphic customer management for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        { "name": "Whilesmart Team" }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Whilesmart\\Customers\\": "src/",
            "Whilesmart\\Customers\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Whilesmart\\Customers\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Whilesmart\\Customers\\CustomersServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
